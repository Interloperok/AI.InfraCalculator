{
  "name": "ai-server-calculator",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "axios": "^1.13.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-joyride": "^2.9.3",
    "recharts": "^3.8.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watchAll=false",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\" \"*.{json,md}\"",
    "eject": "react-scripts eject"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-react-app": "7.0.1",
    "prettier": "3.8.2",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.4.0",
    "typescript": "4.9.5"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.test.{js,jsx,ts,tsx}",
      "!src/index.js",
      "!src/setupTests.js",
      "!src/features/calculator/Calculator.js",
      "!src/features/calculator/CalculatorForm.js",
      "!src/features/gpu/GpuFilterModal.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 75
      }
    }
  }
}
